    "import matplotlib.pyplot as plt\n",
    "\n",
    "# cumulative analysis: total refugees for the requested period (1962-2024)\n",
    "analysis_start_year = 1962\n",
    "analysis_end_year = 2024\n",
    "cumulative_data = data.loc[(data['Year'] >= analysis_start_year) & (data['Year'] <= analysis_end_year)].copy()\n",
    "min_year = int(cumulative_data['Year'].min())\n",
    "max_year = int(cumulative_data['Year'].max())\n",
    "\n",
    "cumulative_host_totals = (\n",
    "    cumulative_data.groupby(['asylum', 'AsylumISO', 'AsylumName'], as_index=False)['Count']\n",
    "    .sum()\n",
    "    .rename(columns={'Count': 'cumulative_refugees'})\n",
    ")\n",
    "population_cumulative = pd.read_csv('Data/Pop.csv').iloc[:, :-1].copy()\n",
    "population_cumulative = population_cumulative.melt(\n",
    "    id_vars=['Country Name', 'Country Code'],\n",
    "    var_name='Year',\n",
    "    value_name='population',\n",
    ")\n",
    "population_cumulative['Year'] = pd.to_numeric(population_cumulative['Year'], errors='coerce')\n",
    "population_cumulative['population'] = pd.to_numeric(population_cumulative['population'], errors='coerce')\n",
    "population_cumulative = population_cumulative.dropna(subset=['Year', 'population'])\n",
    "population_cumulative['Year'] = population_cumulative['Year'].astype(int)\n",
    "population_latest = population_cumulative.loc[\n",
    "    population_cumulative['Year'] == analysis_end_year,\n",
    "    ['Country Name', 'Country Code', 'population'],\n",
    "].dropna(subset=['population'])\n",
    "\n",
    "# use latest population year for per-capita calculation\n",
    "cumulative_per_capita = (\n",
    "    cumulative_host_totals.merge(\n",
    "        population_latest,\n",
    "        left_on='AsylumISO',\n",
    "        right_on='Country Code',\n",
    "        how='left',\n",
    "    )\n",
    "    .assign(\n",
    "        cumulative_per_capita=lambda frame: frame['cumulative_refugees'] / frame['population'],\n",
    "        cumulative_per_100k=lambda frame: frame['cumulative_per_capita'] * 100000,\n",
    "    )\n",
    "    .sort_values('cumulative_refugees', ascending=False)\n",
    "    .reset_index(drop=True)\n",
    ")\n",
    "\n",
    "matched_cumulative = int(cumulative_per_capita['population'].notna().sum())\n",
    "\n",
    "print(f'Cumulative analysis: {min_year}-{max_year}')\n",
